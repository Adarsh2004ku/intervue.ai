# Copy to .env.local for local dev, or set in Vercel → Project → Settings → Environment Variables (Production / Preview).
# Build-time: Vite only exposes variables prefixed with VITE_.

# Vercel “Services” (experimentalServices): same-origin API is under /api/v1 — use a relative base:
# VITE_API_BASE_URL=/api/v1
#
# Single-project / external API host instead:
# VITE_API_BASE_URL=https://your-api.example.com/api/v1
#
# Your backend CORS allow list must include this site’s origin when the API is on another host.
VITE_API_BASE_URL=/api/v1

# Optional. If unset, WebSocket URL is derived from VITE_API_BASE_URL.
# VITE_WS_BASE_URL=wss://your-api.example.com
