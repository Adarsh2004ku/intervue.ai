{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/login/:path*", "destination": "/index.html" },
    { "source": "/auth/callback", "destination": "/index.html" },
    { "source": "/home", "destination": "/index.html" },
    { "source": "/home/:path*", "destination": "/index.html" },
    { "source": "/interview", "destination": "/index.html" },
    { "source": "/interview/:path*", "destination": "/index.html" }
  ]
}
